  <text x="245" y="120" font-family="'Inter', Arial, sans-serif" font-size="60" fill="#4caf50" font-weight="600" transform="rotate(-90, 250, 120)">
    0
  </text>  
  <text x="260" y="95" font-family="'Inter', Arial, sans-serif" font-size="40" fill="#000" font-weight="700" id="engine">
